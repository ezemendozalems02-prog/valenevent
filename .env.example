# Mercado Pago — Checkout Pro
# Access Token de producción o prueba (Panel de desarrollador → Credenciales)
MP_ACCESS_TOKEN=

# Precio de la entrada en ARS (número, sin puntos ni símbolo)
MP_TICKET_PRICE=180000

# Precio mostrado en la landing (texto libre)
NEXT_PUBLIC_TICKET_PRICE_DISPLAY=$180.000

# URL pública del sitio (para las back_urls de Mercado Pago)
NEXT_PUBLIC_SITE_URL=https://estasparamas.com

# Opcional: link de pago directo de Mercado Pago como respaldo
# si la API no está configurada (Herramientas → Link de pago)
NEXT_PUBLIC_MP_PAYMENT_LINK=
